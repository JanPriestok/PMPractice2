<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MasterFloorAPP"
             x:Class="MasterFloorAPP.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary>
                <!-- Заданная цветовая палитра -->
                <Color x:Key="MainBackground">#FFFFFF</Color>
                <Color x:Key="AdditionalBackground">#F4E8D3</Color>
                <Color x:Key="AccentColor">#67BA80</Color>
            </ResourceDictionary>
        </ResourceDictionary>
    </Application.Resources>
</Application>
