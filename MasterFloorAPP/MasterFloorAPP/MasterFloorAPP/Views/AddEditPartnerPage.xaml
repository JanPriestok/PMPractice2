<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MasterFloorAPP.AddEditPartnerPage"
             Title="{Binding Title}">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">

            <!-- Наименование -->
            <VerticalStackLayout Spacing="1">
                <Label Text="Наименование" FontAttributes="Bold" FontSize="14" />
                <Frame BorderColor="Black" CornerRadius="5" Padding="0" Margin="0" HasShadow="False">
                    <Entry Text="{Binding Partner.Name}" BackgroundColor="White" />
                </Frame>
            </VerticalStackLayout>

            <!-- Тип партнёра -->
            <VerticalStackLayout Spacing="2">
                <Label Text="Тип партнёра" FontAttributes="Bold" FontSize="14" />
                <Picker Title="Выберите тип"
        ItemsSource="{Binding PartnerTypes}"
        SelectedItem="{Binding SelectedPartnerType}"
        ItemDisplayBinding="{Binding Name}" />
            </VerticalStackLayout>

            <!-- Рейтинг -->
            <VerticalStackLayout Spacing="1">
                <Label Text="Рейтинг (целое неотрицательное)" FontAttributes="Bold" FontSize="14" />
                <Border Stroke="Black" StrokeThickness="1" Padding="0" Margin="0">
                    <Entry Text="{Binding Partner.Rating}" Keyboard="Numeric" BackgroundColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Фамилия директора -->
            <VerticalStackLayout Spacing="1">
                <Label Text="Фамилия директора" FontAttributes="Bold" FontSize="14" />
                <Border Stroke="Black" StrokeThickness="1" Padding="0" Margin="0">
                    <Entry Text="{Binding Partner.DirectorLastName}" BackgroundColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Имя директора -->
            <VerticalStackLayout Spacing="1">
                <Label Text="Имя директора" FontAttributes="Bold" FontSize="14" />
                <Border Stroke="Black" StrokeThickness="1" Padding="0" Margin="0">
                    <Entry Text="{Binding Partner.DirectorFirstName}" BackgroundColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Отчество директора -->
            <VerticalStackLayout Spacing="1">
                <Label Text="Отчество директора" FontAttributes="Bold" FontSize="14" />
                <Border Stroke="Black" StrokeThickness="1" Padding="0" Margin="0">
                    <Entry Text="{Binding Partner.DirectorMiddleName}" BackgroundColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Телефон -->
            <VerticalStackLayout Spacing="1">
                <Label Text="Телефон" FontAttributes="Bold" FontSize="14" />
                <Border Stroke="Black" StrokeThickness="1" Padding="0" Margin="0">
                    <Entry Text="{Binding Partner.Phone}" BackgroundColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Email -->
            <VerticalStackLayout Spacing="1">
                <Label Text="Email" FontAttributes="Bold" FontSize="14" />
                <Border Stroke="Black" StrokeThickness="1" Padding="0" Margin="0">
                    <Entry Text="{Binding Partner.Email}" BackgroundColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Кнопки -->
            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                <Button Text="Сохранить" Command="{Binding SaveCommand}" HorizontalOptions="FillAndExpand" />
                <Button Text="Назад" Command="{Binding CancelCommand}" HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>