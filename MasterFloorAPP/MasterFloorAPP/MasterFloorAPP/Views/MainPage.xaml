<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MasterFloorAPP.MainPage"
             Title="">

    <Grid RowDefinitions="*">
        <CollectionView Grid.Row="0" 
                        ItemsSource="{Binding Partners}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="10,5,10,5" Padding="10"
                            BackgroundColor="White"
                            Stroke="LightGray"
                            StrokeThickness="1"
                            HorizontalOptions="Fill">
                        <VerticalStackLayout Spacing="8">
                            <!-- тип, название, скидка в правой части -->
                            <Grid ColumnDefinitions="*, Auto">
                                <HorizontalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="{Binding PartnerType}" 
                                           FontAttributes="Bold" FontSize="16" />
                                    <Label Text="|" TextColor="Gray" />
                                    <Label Text="{Binding Name}" 
                                           FontAttributes="Bold" FontSize="16" TextColor="Black" />
                                </HorizontalStackLayout>
                                <Label Grid.Column="1" 
                                       Text="{Binding DiscountPercent, StringFormat='{0}%'}" 
                                       FontSize="16" FontAttributes="Bold" TextColor="Black" 
                                       VerticalOptions="Start" />
                            </Grid>
                            <!-- ФИО директора -->
                            <Label Text="{Binding DirectorFullName}" 
                                   FontSize="14" TextColor="DarkSlateGray" />
                            <!-- Телефон -->
                            <Label Text="{Binding Phone}" FontSize="14" />
                            <!-- Рейтинг -->
                            <HorizontalStackLayout Spacing="20">
                                <Label Text="Рейтинг:" FontSize="14" TextColor="Gray" />
                                <Label Text="{Binding Rating}" FontSize="14" FontAttributes="Bold" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>